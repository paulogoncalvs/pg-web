{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vite Dev (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4005",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "pnpm dev"
    },
    {
      "name": "SSG Debug",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "tsx", "src/vite/ssg.ts"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
