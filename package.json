{
  "name": "@paulogoncalvs/pg-web",
  "version": "1.5.0",
  "description": "Paulo Gonçalves Website",
  "keywords": [
    "playwright",
    "preact",
    "tailwind",
    "typescript",
    "vite",
    "vitest"
  ],
  "homepage": "https://www.paulogoncalves.dev/",
  "license": "MIT",
  "author": "Paulo Gonçalves",
  "repository": {
    "type": "git",
    "url": "https://github.com/paulogoncalvs/pg-web"
  },
  "type": "module",
  "scripts": {
    "ssg": "cross-env NODE_ENV=production tsx src/vite/ssg.ts",
    "build": "vite build && pnpm ssg",
    "preview": "vite preview",
    "prod": "pnpm check && pnpm build && pnpm preview",
    "dev": "vite --port 4005 --host",
    "test": "cross-env NODE_ENV=production vitest run",
    "test:update": "cross-env NODE_ENV=production vitest run -u",
    "test:e2e:install": "docker compose --progress=plain build pg-tests-runner",
    "test:e2e": "docker compose run --remove-orphans pg-tests-runner",
    "test:e2e:update": "docker compose run --remove-orphans pg-tests-runner pnpm exec playwright test --update-snapshots",
    "test:all": "pnpm test && pnpm test:e2e",
    "test:all:update": "pnpm test:update && pnpm test:e2e:update",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt .",
    "check": "pnpm typecheck && pnpm lint && pnpm format",
    "release": "pnpm check && tsx scripts/release.ts"
  },
  "dependencies": {
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.7",
    "web-vitals": "^5.2.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "wouter-preact": "^3.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "axe-core": "^4.11.2",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^17.0.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-node": "^6.0.0",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "^8.0.0"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "overrides": {
      "braces": "^3.0.3",
      "micromatch": "^4.0.8",
      "serialize-javascript": "^7.0.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "sharp"
    ]
  }
}
