{
  "name": "@paulogoncalvs/pg-web",
  "description": "Paulo Gonçalves Website",
  "version": "1.4.5",
  "keywords": [
    "preact",
    "webpack",
    "typescript",
    "tailwind",
    "playwright",
    "jest"
  ],
  "homepage": "https://www.paulogoncalves.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/paulogoncalvs/pg-web"
  },
  "license": "MIT",
  "author": "Paulo Gonçalves",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "30.3.0",
    "@jest/types": "30.3.0",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.27",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "dotenv-webpack": "^9.0.0",
    "esbuild": "^0.27.3",
    "esbuild-jest": "^0.5.0",
    "esbuild-loader": "^4.4.2",
    "esbuild-register": "^3.6.0",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "globals": "^17.4.0",
    "html-webpack-deploy-plugin": "^3.0.0",
    "html-webpack-plugin": "^5.6.6",
    "html-webpack-tags-plugin": "^3.0.2",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-environment-node": "30.3.0",
    "jest-serializer-html": "^7.1.0",
    "lint-staged": "^16.3.2",
    "mini-css-extract-plugin": "^2.10.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "stylelint-webpack-plugin": "^5.1.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.4",
    "webpack-bundle-analyzer": "^5.2.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1",
    "workbox-webpack-plugin": "^7.4.0"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "preact": "^10.28.4",
    "preact-render-to-string": "^6.6.6",
    "tailwindcss": "^4.2.1",
    "web-vitals": "^5.1.0",
    "wouter-preact": "^3.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "braces": "^3.0.3",
      "micromatch": "^4.0.8",
      "postcss": "^8.5.4",
      "serialize-javascript": "^7.0.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "generate:sitemap": "esbuild src/scripts/generateSitemap.ts --bundle --platform=node --format=esm --outfile=dist/generateSitemap.js --external:prettier && node dist/generateSitemap.js",
    "prebuild": "pnpm generate:sitemap",
    "webpack": "tsx ./node_modules/webpack/bin/webpack.js --config webpack/webpack.prod.ts",
    "build": "cross-env NODE_ENV=production tsx ./node_modules/webpack/bin/webpack.js --config webpack/webpack.prod.ts",
    "build:tests": "cross-env NODE_ENV=tests tsx ./node_modules/webpack/bin/webpack.js --config webpack/webpack.prod.ts",
    "start:prod:server": "http-server dist -p 4040",
    "start:prod": "pnpm build && pnpm start:prod:server",
    "start:dev": "tsx ./node_modules/webpack-dev-server/bin/webpack-dev-server.js --config webpack/webpack.dev.ts",
    "tests:jest": "cross-env NODE_ENV=tests jest",
    "tests:jest:update": "pnpm tests:jest -u",
    "tests:pw:build": "tsx ./scripts/run-with-uid-gid.ts docker compose --progress=plain build pg-tests-runner",
    "tests:pw:run": "tsx ./scripts/run-with-uid-gid.ts docker compose run pg-tests-runner",
    "tests:pw": "pnpm build:tests && pnpm tests:pw:run",
    "tests:pw:update": "pnpm build:tests && docker compose run pg-tests-runner pnpm exec playwright test --update-snapshots",
    "tests": "pnpm tests:jest && pnpm tests:pw",
    "tests:update": "pnpm tests:jest:update && pnpm tests:pw:update",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint:ts": "tsc --noEmit && eslint .",
    "lint:ts:fix": "eslint . --fix",
    "lint:css": "stylelint ./src/**/*.css",
    "lint:css:fix": "stylelint ./src/**/*.css --fix",
    "lint": "pnpm lint:ts && pnpm lint:css",
    "lint:fix": "pnpm lint:ts:fix && pnpm lint:css:fix"
  }
}
