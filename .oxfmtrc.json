{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",

  "ignorePatterns": ["dist/**", "node_modules/**"],

  "format": {
    "indent": { "style": "space", "width": 4 },
    "lineWidth": 120,
    "semi": true,
    "singleQuote": true,
    "jsxSingleQuote": false,
    "trailingCommas": "all",
    "arrowParens": "always",
    "lineTerminator": "lf"
  },

  "overrides": [
    {
      "files": ["**/*.json", "**/.*rc/**", "**/*.yml", "**/*.css"],
      "options": {
        "indent": { "style": "space", "width": 2 }
      }
    },
    {
      "files": ["**/*.md"],
      "options": {
        "lineWidth": 80,
        "indent": { "style": "space", "width": 2 }
      }
    }
  ]
}
