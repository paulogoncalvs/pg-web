# -----------------------------
# Base image: Node.js
# -----------------------------
FROM node:24-slim@sha256:24dc26ef1e3c3690f27ebc4136c9c186c3133b25563ae4d7f0692e4d1fe5db0e

# -----------------------------
# Install PNPM
# -----------------------------
ENV PNPM_HOME=/root/.local/share/pnpm
ENV PATH=$PATH:$PNPM_HOME
RUN npm i -g pnpm@11.1.1

# -----------------------------
# Working directory
# -----------------------------
WORKDIR /app

# -----------------------------
# Copy and install dependencies
# -----------------------------
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile --prefer-offline

# -----------------------------
# Copy all source files
# -----------------------------
COPY . .

# -----------------------------
# Copy environment files
# -----------------------------
COPY .env.test .env.production

# -----------------------------
# Install Playwright browsers
# -----------------------------
RUN pnpm add -D @playwright/test && pnpm exec playwright install --with-deps chromium

# -----------------------------
# Build the project
# -----------------------------
RUN pnpm run build

# -----------------------------
# Expose port
# -----------------------------
EXPOSE 4040

# -----------------------------
# Run tests
# -----------------------------
CMD ["pnpm", "exec", "playwright", "test", "--reporter=line"]
