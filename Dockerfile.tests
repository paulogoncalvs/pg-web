# Base image: Playwright + Ubuntu focal
FROM mcr.microsoft.com/playwright:focal

# Build arguments (optional for UID/GID mapping in docker-compose)
ARG UID=1000
ARG GID=1000
ARG UNAME=node

# -----------------------------
# Create unprivileged user
# -----------------------------
RUN groupadd --gid ${GID} --non-unique ${UNAME} \
    && useradd --create-home --uid ${UID} --gid ${GID} --non-unique --shell /bin/bash ${UNAME}

# -----------------------------
# Install Node 24 and PNPM
# -----------------------------
USER root
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && npm i -g pnpm@10.30.3

# -----------------------------
# Use existing user for subsequent steps
# -----------------------------
USER ${UNAME}
WORKDIR /app

# -----------------------------
# Copy package files first (for caching)
# -----------------------------
COPY --chown=$UNAME:$UNAME package.json pnpm-lock.yaml ./

# -----------------------------
# Install dependencies
# -----------------------------
RUN pnpm install --frozen-lockfile --prefer-offline

# -----------------------------
# Copy the rest of the project
# -----------------------------
COPY --chown=$UNAME:$UNAME  . .
COPY --chown=$UNAME:$UNAME .env.tests .env.production

# -----------------------------
# Pre-create Playwright output folders outside src
# -----------------------------
RUN mkdir -p /app/playwright-results /app/playwright-report

# -----------------------------
# Install Chromium for Playwright tests
# -----------------------------
USER root
RUN pnpm exec playwright install --with-deps chromium

# -----------------------------
# Build the project
# -----------------------------
USER ${UNAME}
RUN pnpm run build

# -----------------------------
# Expose port if needed
# -----------------------------
EXPOSE 4040

# -----------------------------
# Default command for CI
# -----------------------------
CMD ["pnpm", "exec", "playwright", "test"]