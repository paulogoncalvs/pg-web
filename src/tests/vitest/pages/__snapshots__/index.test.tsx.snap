exports[`[PAGE CONTENT] 404 Page > should render 1`] = `"<h1 class="px-6 pt-16"><span style="--delay:100ms;" class="animate-base op-low">Oops!</span><span style="--delay:200ms;" class="animate-base op-low">Page not found</span></h1><div style="--delay:400ms;" class="animate-base op-low px-6 pb-16"><a href="/undefined/" class="interactive interactive-lg">Go to homepage</a></div>"`;

exports[`[PAGE CONTENT] Contact Page > should render 1`] = `"<h1 class="px-6 pt-16"><span style="--delay:100ms;" class="animate-base op-low">Contact</span><span style="--delay:200ms;" class="animate-base op-low">send me a message</span></h1><div class="flex flex-col items-center px-6 text-left"><form novalidate class="w-full max-w-md space-y-4"><h2 style="--delay:200ms;" class="animate-base op-low mb-8 text-xl font-bold sm:text-2xl">By form:</h2><div style="--delay:220.00000000000003ms;" class="animate-base op-low"><div class="form-field mt-3"><label for="firstName" class="form-label">First name</label><input id="firstName" type="text" name="firstName" value autocomplete="given-name" class="form-input "/></div></div><div style="--delay:240ms;" class="animate-base op-low"><div class="form-field mt-3"><label for="lastName" class="form-label">Last name</label><input id="lastName" type="text" name="lastName" value autocomplete="family-name" class="form-input "/></div></div><div style="--delay:260ms;" class="animate-base op-low"><div class="form-field mt-3"><label for="email" class="form-label">E-mail</label><input id="email" type="email" name="email" value autocomplete="email" class="form-input "/></div></div><div style="--delay:280ms;" class="animate-base op-low"><div class="form-field mt-3"><label for="message" class="form-label">Message</label><textarea id="message" name="message" rows="4" autocomplete="off" class="form-input "></textarea></div></div><div class="form-field mt-3 hidden"><label for="company" class="form-label">Message</label><input id="company" type="text" name="company" value autocomplete="off" class="form-input "/></div><div style="--delay:300ms;" class="animate-base op-low"><button class="btn interactive interactive-icon interactive-md"><svg aria-hidden="true" aria-label width="24" height="24" class="fill-current"><use href="#"></use></svg>Send message</button></div></form></div><div class="flex flex-col items-center px-6 pb-16 text-left"><div class="w-full max-w-md space-y-8"><h2 style="--delay:100ms;" class="animate-base op-low">By e-mail:</h2><div style="--delay:200ms;" class="animate-base op-low"><a href="mailto:contact@paulogoncalves.dev" class="interactive interactive-icon interactive-md"><svg aria-hidden="true" aria-label width="24" height="24" class="fill-current"><use href="#"></use></svg>Send e-mail</a></div></div></div>"`;

exports[`[PAGE CONTENT] Home Page > should render 1`] = `"<section class="flex flex-col items-center space-y-14 px-6 pt-16"><h1><span style="--delay:100ms;" class="animate-base op-low">PAULO GONÇALVES</span><span style="--delay:200ms;" class="animate-base op-low">Front-End Engineer</span></h1><div class="flex flex-col items-center space-y-14 sm:flex-row sm:space-y-0"><div style="--delay:300ms;" class="animate-base op-low shrink-0"><img alt="portrait of Paulo Gonçalves" width="240" height="240" src="/src/assets/img/paulo-goncalves-240.jpeg" srcset="/src/assets/img/paulo-goncalves-240.jpeg 1x, /src/assets/img/paulo-goncalves-400.jpeg 2x" sizes="(max-width: 640px) 240px, 240px" loading="eager" decoding="async" fetchpriority="high" class="transition-all duration-500 ease-out motion-reduce:transition-none opacity-60 rounded-full border border-white/20 bg-white/30 shadow-[inset_0_1px_0_rgba(255,255,255,0.75),0_0_9px_rgba(0,0,0,0.2),0_3px_8px_rgba(0,0,0,0.15)]"/></div><div style="--delay:400ms;" class="animate-base op-low max-w-sm text-left text-sm sm:max-w-lg sm:pl-14 sm:text-base"><p>Native of Vila Nova de Gaia, Porto, Portugal.<br /><br />With more than 20 years of professional experience, I am currently a <strong>Principal Front-End Engineer</strong> at <strong>Porto Tech Center - Jumia</strong>, focused on building scalable, high-performance web applications.<br /><br />I lead front-end architecture, define technical direction, and promote best practices while leveraging modern frameworks and tooling.<br /><br />Driven by performance and user experience, I collaborate across teams to deliver robust, user-centric solutions and tackle complex engineering challenges.</p></div></div></section><section class="flex flex-col items-center border-t border-white/80 bg-white/5 px-6 py-16 text-center dark:border-white/15 dark:bg-zinc-900/15"><div class="w-full max-w-sm text-left sm:max-w-xl"><h2 style="--delay:200ms;" class="animate-base op-low mb-12">Professional Experience</h2><div style="--delay:200ms;" class="animate-base op-low"><div style="--delay:0ms;" class="animate-base op-low"><div class="my-11 last:mb-0"><h3 class="text-lg font-semibold text-zinc-800 dark:text-zinc-200">Jumia Porto Tech Center</h3><p class="mb-3 text-sm text-stone-500 dark:text-zinc-400">11 years 3 months</p><div class="relative ml-3"><span class="absolute top-3 bottom-0 -left-0.5 w-2 -translate-x-1/3 rounded bg-stone-300/60 dark:bg-white/5"></span><div class="space-y-4"><div style="--delay:0ms;" class="animate-base op-low"><div class="relative pl-6"><span class="absolute top-1 -left-2.25 h-4 w-4 rounded-full border-3 border-stone-400 bg-black dark:border-zinc-500 dark:bg-white"></span><h4 class="font-semibold text-zinc-900 dark:text-white">Principal Front-End Engineer</h4><p class="text-xs text-stone-500 dark:text-zinc-400">Oct 2022 – Present · 3 years 4 months</p></div></div><div style="--delay:15ms;" class="animate-base op-low"><div class="relative pl-6"><span class="absolute top-1 -left-2.25 h-4 w-4 rounded-full border-3 border-stone-400 bg-stone-100 dark:border-white/10 dark:bg-zinc-700"></span><h4 class="font-semibold text-zinc-900 dark:text-white">Engineering Manager / Lead Front-End Engineer</h4><p class="text-xs text-stone-500 dark:text-zinc-400">Sep 2021 – Oct 2022 · 1 year 2 months</p></div></div><div style="--delay:30ms;" class="animate-base op-low"><div class="relative pl-6"><span class="absolute top-1 -left-2.25 h-4 w-4 rounded-full border-3 border-stone-400 bg-stone-100 dark:border-white/10 dark:bg-zinc-700"></span><h4 class="font-semibold text-zinc-900 dark:text-white">Lead Front-End Engineer</h4><p class="text-xs text-stone-500 dark:text-zinc-400">Jun 2020 – Aug 2021 · 1 year 3 months</p></div></div><div style="--delay:44.99999999999999ms;" class="animate-base op-low"><div class="relative pl-6"><span class="absolute top-1 -left-2.25 h-4 w-4 rounded-full border-3 border-stone-400 bg-stone-100 dark:border-white/10 dark:bg-zinc-700"></span><h4 class="font-semibold text-zinc-900 dark:text-white">Web Engineer (Senior Front-End Engineer)</h4><p class="text-xs text-stone-500 dark:text-zinc-400">Apr 2016 – Jun 2020 · 4 years 3 months</p></div></div><div style="--delay:60ms;" class="animate-base op-low"><div class="relative pl-6"><span class="absolute top-1 -left-2.25 h-4 w-4 rounded-full border-3 border-stone-400 bg-stone-100 dark:border-white/10 dark:bg-zinc-700"></span><h4 class="font-semibold text-zinc-900 dark:text-white">Senior Front-End Developer</h4><p class="text-xs text-stone-500 dark:text-zinc-400">Nov 2014 – Apr 2016 · 1 year 6 months</p></div></div></div></div></div></div><div style="--delay:20ms;" class="animate-base op-low"><div class="my-11 last:mb-0"><h3 class="text-lg font-semibold text-zinc-800 dark:text-zinc-200">Rocket Internet GmbH</h3><p class="mb-3 text-sm text-stone-500 dark:text-zinc-400">2 years 6 months</p><div class="relative ml-3"><span class="absolute top-3 bottom-0 -left-0.5 w-2 -translate-x-1/3 rounded bg-stone-300/60 dark:bg-white/5"></span><div class="space-y-4"><div style="--delay:0ms;" class="animate-base op-low"><div class="relative pl-6"><span class="absolute top-1 -left-2.25 h-4 w-4 rounded-full border-3 border-stone-400 bg-stone-100 dark:border-white/10 dark:bg-zinc-700"></span><h4 class="font-semibold text-zinc-900 dark:text-white">Advanced Developer</h4><p class="text-xs text-stone-500 dark:text-zinc-400">Jun 2012 – Nov 2014 · 2 years 6 months</p></div></div></div></div></div></div><div style="--delay:40ms;" class="animate-base op-low"><div class="my-11 last:mb-0"><h3 class="text-lg font-semibold text-zinc-800 dark:text-zinc-200">Myone - Comunicação Multimédia</h3><p class="mb-3 text-sm text-stone-500 dark:text-zinc-400">3 years 8 months</p><div class="relative ml-3"><span class="absolute top-3 bottom-0 -left-0.5 w-2 -translate-x-1/3 rounded bg-stone-300/60 dark:bg-white/5"></span><div class="space-y-4"><div style="--delay:0ms;" class="animate-base op-low"><div class="relative pl-6"><span class="absolute top-1 -left-2.25 h-4 w-4 rounded-full border-3 border-stone-400 bg-stone-100 dark:border-white/10 dark:bg-zinc-700"></span><h4 class="font-semibold text-zinc-900 dark:text-white">Multimedia Engineer</h4><p class="text-xs text-stone-500 dark:text-zinc-400">Oct 2008 – May 2012 · 3 years 8 months</p></div></div></div></div></div></div><div style="--delay:60.00000000000001ms;" class="animate-base op-low"><div class="my-11 last:mb-0"><h3 class="text-lg font-semibold text-zinc-800 dark:text-zinc-200">Medula - Design de Comunicação</h3><p class="mb-3 text-sm text-stone-500 dark:text-zinc-400">1 year 1 month</p><div class="relative ml-3"><span class="absolute top-3 bottom-0 -left-0.5 w-2 -translate-x-1/3 rounded bg-stone-300/60 dark:bg-white/5"></span><div class="space-y-4"><div style="--delay:0ms;" class="animate-base op-low"><div class="relative pl-6"><span class="absolute top-1 -left-2.25 h-4 w-4 rounded-full border-3 border-stone-400 bg-stone-100 dark:border-white/10 dark:bg-zinc-700"></span><h4 class="font-semibold text-zinc-900 dark:text-white">Web Designer | New Media Developer</h4><p class="text-xs text-stone-500 dark:text-zinc-400">Sep 2007 – Sep 2008 · 1 year 1 month</p></div></div></div></div></div></div><div style="--delay:80ms;" class="animate-base op-low"><div class="my-11 last:mb-0"><h3 class="text-lg font-semibold text-zinc-800 dark:text-zinc-200">Freelance</h3><p class="mb-3 text-sm text-stone-500 dark:text-zinc-400">3 years 8 months</p><div class="relative ml-3"><span class="absolute top-3 bottom-0 -left-0.5 w-2 -translate-x-1/3 rounded bg-stone-300/60 dark:bg-white/5"></span><div class="space-y-4"><div style="--delay:0ms;" class="animate-base op-low"><div class="relative pl-6"><span class="absolute top-1 -left-2.25 h-4 w-4 rounded-full border-3 border-stone-400 bg-stone-100 dark:border-white/10 dark:bg-zinc-700"></span><h4 class="font-semibold text-zinc-900 dark:text-white">Freelance Web Developer/Designer</h4><p class="text-xs text-stone-500 dark:text-zinc-400">Jan 2004 – Aug 2007 · 3 years 8 months</p></div></div></div></div></div></div></div><p style="--delay:100ms;" class="animate-base op-low pt-12 text-sm italic">For more technical details and experience, please visit my <a href="https://www.linkedin.com/in/paulogoncalvs" rel="noopener noreferrer" target="_blank" class="underline">LinkedIn profile</a>.</p></div></section>"`;

exports[`[PAGE CONTENT] Offline Page > should render 1`] = `"<h1 class="px-6 pt-16"><span style="--delay:100ms;" class="animate-base op-low">Oops!</span><span style="--delay:200ms;" class="animate-base op-low">You are currently offline</span></h1><div style="--delay:400ms;" class="animate-base op-low px-6"><p>You need an Internet connection.</p></div><div style="--delay:600ms;" class="animate-base op-low px-6 pb-16"><a href="/undefined/" class="interactive interactive-lg">Go back to homepage</a></div>"`;
