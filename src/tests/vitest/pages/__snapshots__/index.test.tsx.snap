exports[`[PAGE CONTENT] Home Page > should render 1`] = `"<section class="flex flex-col items-center space-y-14 px-6 pt-16"><h1><span style="--delay:100ms;" class="animate-base op-low">PAULO GONÇALVES</span><span style="--delay:200ms;" class="animate-base op-low">Front-End Engineer</span></h1><div class="flex flex-col items-center space-y-14 sm:flex-row sm:space-y-0"><div style="--delay:300ms;" class="animate-base op-low shrink-0"><img alt="portrait of Paulo Gonçalves" width="240" height="240" src="/src/assets/img/paulo-goncalves-240.jpeg" srcset="/src/assets/img/paulo-goncalves-240.jpeg 1x, /src/assets/img/paulo-goncalves-400.jpeg 2x" sizes="(max-width: 640px) 240px, 240px" loading="eager" decoding="async" fetchpriority="high" class="transition-opacity duration-500 ease-out motion-reduce:transition-none opacity-60 rounded-full border border-white/20 bg-white/30 shadow-[inset_0_1px_0_rgba(255,255,255,0.75),0_0_9px_rgba(0,0,0,0.2),0_3px_8px_rgba(0,0,0,0.15)]"/></div><div style="--delay:400ms;" class="animate-base op-low max-w-sm text-left text-sm sm:max-w-lg sm:pl-14 sm:text-base"><p>Native of Vila Nova de Gaia, Porto, Portugal.<br /><br />With more than 20 years of professional experience, I am currently a <strong>Principal Front-End Engineer</strong> at <strong>Porto Tech Center - Jumia</strong>, focused on building scalable, high-performance web applications.<br /><br />I lead front-end architecture, define technical direction, and promote best practices while leveraging modern frameworks and tooling.<br /><br />Driven by performance and user experience, I collaborate across teams to deliver robust, user-centric solutions and tackle complex engineering challenges.</p></div></div></section><section class="flex flex-col items-center border-t border-white/80 bg-white/5 px-6 py-16 text-center dark:border-white/15 dark:bg-zinc-900/15"><div class="w-full max-w-sm text-left sm:max-w-xl"><h2 style="--delay:200ms;" class="animate-base op-low mb-12">Professional Experience<